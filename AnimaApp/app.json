{
  "expo": {
    "name": "AnimaApp",
    "slug": "animaapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/mascot/respirando.png",
    "scheme": "animaapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/mascot/respirando.png",
      "resizeMode": "contain",
      "backgroundColor": "#E8F4FD"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anima.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/mascot/respirando.png",
        "backgroundColor": "#E8F4FD"
      },
      "package": "com.anima.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/mascot/respirando.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/mascot/respirando.png",
          "color": "#C8B6FF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a6c6e783-eec0-4211-98a9-e63e157c0402"
      }
    }
  }
}
